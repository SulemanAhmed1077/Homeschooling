<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="24dp">

        <!-- Top Handle -->
        <View
            android:layout_width="50dp"
            android:layout_height="5dp"
            android:background="#DDDDDD"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tuition Details"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="20dp"/>

        <!-- 1. Child's Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Child's Name *"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginBottom="5dp"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#F0F2F5"
            android:paddingLeft="15dp"
            android:hint="Enter child's name"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginBottom="15dp"/>

        <!-- 2. Class/Grade -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Class/Grade *"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginBottom="5dp"/>

        <EditText
            android:id="@+id/etClass"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#F0F2F5"
            android:paddingLeft="15dp"
            android:hint="e.g. 10th Grade"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginBottom="15dp"/>

        <!-- 3. Subjects Needed -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subjects Needed *"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginBottom="5dp"/>

        <EditText
            android:id="@+id/etSubjects"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#F0F2F5"
            android:paddingLeft="15dp"
            android:hint="e.g. Maths, Physics"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginBottom="15dp"/>

        <!-- 4. Preferred Timings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preferred Timings"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginBottom="5dp"/>

        <EditText
            android:id="@+id/etTimings"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#F0F2F5"
            android:paddingLeft="15dp"
            android:hint="e.g. After 5 PM"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginBottom="15dp"/>

        <!-- 5. Monthly Fee -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monthly Fee (PKR) *"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginBottom="5dp"/>

        <EditText
            android:id="@+id/etFee"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#F0F2F5"
            android:paddingLeft="15dp"
            android:hint="0"
            android:inputType="number"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginBottom="15dp"/>

        <!-- 6. Days per Month (NEW) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Days per Month *"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginBottom="5dp"/>

        <EditText
            android:id="@+id/etDays"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#F0F2F5"
            android:paddingLeft="15dp"
            android:hint="e.g. 23"
            android:inputType="number"
            android:textColor="#000000"
            android:textSize="14sp"
            android:layout_marginBottom="10dp"/>

        <!-- 7. About Days & Payment Text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="About Days &amp; Payment:\nPayment is calculated based on the selected days per month. Any changes will be reflected in the escrow."
            android:textColor="#999999"
            android:textSize="11sp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="25dp"
            android:lineSpacingExtra="2dp"/>

        <!-- 8. Create Request Button -->
        <Button
            android:id="@+id/btnCreate"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Create Request"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:backgroundTint="#1565C0"/>

    </LinearLayout>
</ScrollView>