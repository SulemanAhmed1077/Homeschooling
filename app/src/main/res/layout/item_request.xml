<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Child Name & Class -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvChildName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Child: Ali"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <TextView
                android:id="@+id/tvClass"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10th Grade"
                android:textSize="14sp"
                android:textColor="#757575"
                android:background="#E0E0E0"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>
        </LinearLayout>

        <!-- Details: Parent, Subjects -->
        <TextView
            android:id="@+id/tvParentName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parent: Mr. Khan"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvSubjects"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subjects: Maths, Physics"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="8dp"/>

        <!-- Fee & Days Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvFee"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Fee: 5000 PKR"
                android:textStyle="bold"
                android:textColor="#1565C0"/>

            <TextView
                android:id="@+id/tvDays"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="23 Days"
                android:textSize="12sp"
                android:textColor="#555555"/>
        </LinearLayout>

        <!-- Button 1: Accept Request (Tutors ke liye) -->
        <Button
            android:id="@+id/btnAcceptRequest"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Accept Request"
            android:textAllCaps="false"
            android:backgroundTint="#4CAF50"
            app:cornerRadius="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- Button 2: Mark Attendance (Parents ke liye) -->
        <Button
            android:id="@+id/btnMarkAttendance"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="Mark Attendance"
            android:textAllCaps="false"
            android:backgroundTint="#2196F3"
            app:cornerRadius="8dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>